{
  "name": "newposv1",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@3.6.4",
  "description": "IMPOS2 - Enterprise POS System with Layered Architecture",
  "workspaces": [
    "0-mock-server/*",
    "0-mock-server/kernel-server/web",
    "0-mock-server/mock-terminal-platform/*",
    "1-kernel/*",
    "1-kernel/1.1-base/*",
    "1-kernel/1.1-cores/*",
    "1-kernel/1.2-modules/*",
    "2-ui/2.1-base/*",
    "2-ui/2.1-cores/*",
    "2-ui/2.2-modules/*",
    "2-ui/2.3-integration/*",
    "2-ui/2.3-integrations/*",
    "3-adapter/*",
    "3-adapter/android/*",
    "3-adapter/electron/*",
    "3-adapter/tauri/*",
    "4-assembly/*",
    "4-assembly/android/*",
    "4-assembly/electron/*"
  ],
  "scripts": {
    "setup": "corepack yarn install",
    "create-package": "node scripts/create-package.cjs",
    "build:clean": "turbo run build --force",
    "build": "turbo run build",
    "build-for-product": "turbo run build-for-product",
    "build-for-product:clean": "turbo run build-for-product --force",
    "check-env": "node scripts/check-env.cjs",
    "type-check": "turbo run type-check",
    "check:workspace-local-artifacts": "node scripts/check-workspace-local-artifacts.cjs",
    "kill-port": "node scripts/kill-port.mjs",
    "android:port-forward": "node scripts/setup-android-port-forwarding.mjs",
    "android:port-list": "node scripts/setup-android-port-forwarding.mjs --list",
    "android:port-clear": "node scripts/setup-android-port-forwarding.mjs --clear",
    "-------": "---------------------------------------",
    "A:kernel-server": "corepack yarn workspace @impos2/kernel-server dev",
    "B:master-ws-server-dual": "corepack yarn workspace @impos2/master-ws-server-dual dev",
    "C:mock-terminal-platform": "corepack yarn workspace @impos2/mock-terminal-platform dev",
    "mock:platform:dev": "corepack yarn workspace @impos2/mock-terminal-platform dev",
    "mock:platform:type-check": "corepack yarn workspace @impos2/mock-terminal-platform type-check",
    "---------": "---------------------------------------",
    "kernel:core-base": "corepack yarn workspace @impos2/kernel-core-base dev",
    "kernel:core-interconnection-master": "corepack yarn workspace @impos2/kernel-core-interconnection master",
    "kernel:core-interconnection-slave": "corepack yarn workspace @impos2/kernel-core-interconnection slave",
    "kernel:core-navigation": "corepack yarn workspace @impos2/kernel-core-navigation dev",
    "kernel:core-task": "corepack yarn workspace @impos2/kernel-core-task dev",
    "kernel:module-terminal": "corepack yarn workspace @impos2/kernel-core-terminal dev",
    "-------------": "----------------------------------------",
    "ui:core-base": "yarn workspace @impos2/ui-core-base web",
    "ui:core-runtime-base": "yarn workspace @impos2/ui-core-runtime-base web",
    "ui:core-admin": "yarn workspace @impos2/ui-core-admin web",
    "ui:core-terminal": "yarn workspace @impos2/ui-core-terminal web",
    "ui:module-mixc-user": "yarn workspace @impos2/ui-mixc-user web",
    "ui:integrate-mixc-retail": "yarn workspace @impos2/ui-integration-mixc-retail web",
    "--------": "---------------------------------------",
    "adapter:android-pure:build": "corepack yarn workspace @impos2/adapter-android-pure build:android",
    "adapter:android-pure:all": "corepack yarn workspace @impos2/adapter-android-pure android:all",
    "adapter:android-v2:build": "corepack yarn workspace @impos2/adapter-android-v2 build:android",
    "adapter:android-v2:all": "corepack yarn workspace @impos2/adapter-android-v2 android:all",
    "-----------": "---------------------------------------",
    "adapter:electron-dev-app:dev": "corepack yarn workspace @impos2/adapter-electron-dev-app dev",
    "adapter:electron-dev-app:package": "corepack yarn workspace @impos2/adapter-electron-dev-app package",
    "assembly:android-mixc-retail-rn84:metro": "corepack yarn workspace @impos2/assembly-android-mixc-retail-rn84 start:clean",
    "assembly:android-mixc-retail-rn84:run": "corepack yarn workspace @impos2/assembly-android-mixc-retail-rn84 android:run",
    "adapter:electron-v1:type-check": "corepack yarn workspace @impos2/adapter-electron-v1 type-check",
    "assembly:electron-mixc-retail-v1:dev": "corepack yarn workspace @impos2/assembly-electron-mixc-retail-v1 dev",
    "assembly:electron-mixc-retail-v1:package": "corepack yarn workspace @impos2/assembly-electron-mixc-retail-v1 package",
    "assembly:electron-mixc-retail-v1:make": "corepack yarn workspace @impos2/assembly-electron-mixc-retail-v1 make",
    "------------": "---------------------------------------",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "turbo run lint",
    "release:manifest:prepare": "node scripts/release/prepare-release-manifest.cjs",
    "release:assembly:sync-package-version": "node scripts/release/sync-assembly-version.cjs",
    "release:assembly:sync-android-version": "node scripts/release/sync-android-version.cjs",
    "release:assembly:bump": "node scripts/release/bump-assembly-version.cjs",
    "release:bundle:bump": "node scripts/release/bump-bundle-version.cjs",
    "release:assembly:sync-electron-version": "node scripts/release/sync-electron-version.cjs",
    "release:assembly:bump-build-number": "node scripts/release/bump-build-number.cjs",
    "release:manifest:validate": "node scripts/release/validate-release-manifest.cjs",
    "release:manifest:inject-git": "node scripts/release/inject-git-metadata.cjs",
    "release:assembly:android:full": "node scripts/release/release-assembly-android-full.cjs",
    "release:bundle:full": "node scripts/release/release-bundle-full.cjs",
    "release:manifest:finalize": "node scripts/release/finalize-release-manifest.cjs",
    "release:assembly:generate-release-info": "node scripts/release/generate-assembly-release-info.cjs",
    "release:assembly:electron:full": "node scripts/release/release-assembly-electron-full.cjs",
    "release:manifest:generate-note": "node scripts/release/generate-release-note.cjs",
    "release:package:generate-version-info": "node scripts/release/generate-package-version-info.cjs"
  },
  "devDependencies": {
    "@react-native-community/cli-plugin-metro": "^12.3.6",
    "inquirer": "^8.2.6",
    "turbo": "latest",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@reduxjs/toolkit": "^2.11.2",
    "redux": "^5.0.1",
    "redux-observable": "^3.0.0-rc.3",
    "rxjs": "^7.8.2",
    "typescript": "^5.9.3",
    "ts-node": "^10.9.2",
    "@types/node": "^25.0.9",
    "node-localstorage": "^3.0.5",
    "better-sqlite3": "^12.6.2",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "monaco-editor": "^0.52.2"
  },
  "dependencies": {
    "react-native-svg": "^15.15.3"
  }
}
