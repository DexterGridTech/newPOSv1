{
  "name": "newposv1",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@3.6.4",
  "description": "NEXT - Enterprise POS System with Layered Architecture",
  "workspaces": [
    "0-mock-server/dual-topology-host-v3",
    "0-mock-server/mock-admin-mall-tenant-console",
    "0-mock-server/mock-admin-mall-tenant-console/*",
    "0-mock-server/mock-terminal-platform",
    "0-mock-server/mock-terminal-platform/*",
    "1-kernel/server-config-v2",
    "1-kernel/1.1-base/*",
    "1-kernel/1.2-business/*",
    "2-ui/2.1-base/*",
    "2-ui/2.2-business/*",
    "2-ui/2.3-integration/*",
    "3-adapter/android/adapter-android-v2",
    "3-adapter/android/host-runtime-rn84",
    "4-assembly/android/mixc-catering-assembly-rn84"
  ],
  "scripts": {
    "setup": "corepack yarn install",
    "build:clean": "turbo run build --force",
    "build": "turbo run build",
    "build-for-product": "turbo run build-for-product",
    "build-for-product:clean": "turbo run build-for-product --force",
    "check-env": "node scripts/check-env.cjs",
    "type-check": "turbo run type-check",
    "check:workspace-local-artifacts": "node scripts/check-workspace-local-artifacts.cjs",
    "kill-port": "node scripts/kill-port.mjs",
    "android:port-forward": "node scripts/setup-android-port-forwarding.mjs",
    "android:port-list": "node scripts/setup-android-port-forwarding.mjs --list",
    "android:port-clear": "node scripts/setup-android-port-forwarding.mjs --clear",
    "android:automation:forward": "node scripts/android-automation-rpc.mjs forward",
    "android:automation:hello": "node scripts/android-automation-rpc.mjs hello",
    "android:automation:smoke": "node scripts/android-automation-rpc.mjs smoke",
    "android:automation:call": "node scripts/android-automation-rpc.mjs call",
    "android:automation:press": "node scripts/android-automation-rpc.mjs press",
    "android:automation:type-virtual": "node scripts/android-automation-rpc.mjs type-virtual",
    "android:automation:activate-device": "node scripts/android-automation-rpc.mjs activate-device",
    "android:automation:wait-activated": "node scripts/android-automation-rpc.mjs wait-activated",
    "android:automation:admin-login": "node scripts/android-automation-rpc.mjs admin-login",
    "android:automation:deactivate-device": "node scripts/android-automation-rpc.mjs deactivate-device",
    "mock:platform:prepare-activation": "node scripts/mock-platform-prepare-activation.mjs",
    "-------": "---------------------------------------",
    "A:mock-terminal-platform": "corepack yarn workspace @next/mock-terminal-platform dev",
    "B:dual-topology-host-v3": "corepack yarn workspace @next/dual-topology-host-v3 start",
    "mock:platform:dev": "corepack yarn workspace @next/mock-terminal-platform dev",
    "mock:platform:type-check": "corepack yarn workspace @next/mock-terminal-platform type-check",
    "mock:admin-mall-tenant-console:dev": "corepack yarn workspace @next/mock-admin-mall-tenant-console dev",
    "mock:admin-mall-tenant-console:type-check": "corepack yarn workspace @next/mock-admin-mall-tenant-console type-check",
    "admin-mall-master-data:restore": "node scripts/admin-mall-tenant-master-data-restore.mjs",
    "admin-mall-master-data:restore-clean": "node scripts/admin-mall-tenant-master-data-restore.mjs --clean-hot-update --relaunch-app --ensure-activated",
    "admin-mall-master-data:smoke": "node scripts/admin-mall-tenant-master-data-smoke.mjs",
    "---------": "---------------------------------------",
    "kernel:base:topology-runtime-v3:test": "corepack yarn workspace @next/kernel-base-topology-runtime-v3 test",
    "kernel:base:tdp-sync-runtime-v2:test": "corepack yarn workspace @next/kernel-base-tdp-sync-runtime-v2 test",
    "-------------": "----------------------------------------",
    "ui:base:runtime-react:test": "corepack yarn workspace @next/ui-base-runtime-react test",
    "ui:base:topology-runtime-bridge:test": "corepack yarn workspace @next/ui-base-topology-runtime-bridge test",
    "--------": "---------------------------------------",
    "adapter:android-v2:build": "corepack yarn workspace @next/adapter-android-v2 build:android",
    "adapter:android-v2:all": "corepack yarn workspace @next/adapter-android-v2 android:all",
    "-----------": "---------------------------------------",
    "------------": "---------------------------------------",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "turbo run lint",
    "release:manifest:prepare": "node scripts/release/prepare-release-manifest.cjs",
    "release:assembly:sync-package-version": "node scripts/release/sync-assembly-version.cjs",
    "release:assembly:sync-android-version": "node scripts/release/sync-android-version.cjs",
    "release:assembly:bump": "node scripts/release/bump-assembly-version.cjs",
    "release:bundle:bump": "node scripts/release/bump-bundle-version.cjs",
    "release:assembly:bump-build-number": "node scripts/release/bump-build-number.cjs",
    "release:manifest:validate": "node scripts/release/validate-release-manifest.cjs",
    "release:manifest:inject-git": "node scripts/release/inject-git-metadata.cjs",
    "release:assembly:android:full": "node scripts/release/release-assembly-android-full.cjs",
    "release:bundle:full": "node scripts/release/release-bundle-full.cjs",
    "release:manifest:finalize": "node scripts/release/finalize-release-manifest.cjs",
    "release:assembly:generate-release-info": "node scripts/release/generate-assembly-release-info.cjs",
    "release:manifest:generate-note": "node scripts/release/generate-release-note.cjs",
    "release:package:generate-version-info": "node scripts/release/generate-package-version-info.cjs",
    "release:hot-update:package": "node scripts/release/package-hot-update.cjs",
    "ui:integration-catering-shell:web": "corepack yarn workspace @next/ui-integration-catering-shell web",
    "assembly:android-mixc-catering-rn84:metro": "corepack yarn workspace @next/assembly-android-mixc-catering-assembly-rn84 start:clean",
    "assembly:android-mixc-catering-rn84:run": "corepack yarn workspace @next/assembly-android-mixc-catering-assembly-rn84 android:run",
    "assembly:android-mixc-catering-rn84:test-visible:admin-loop": "corepack yarn workspace @next/assembly-android-mixc-catering-assembly-rn84 test-visible:admin-loop"
  },
  "devDependencies": {
    "@react-native-community/cli-plugin-metro": "^12.3.6",
    "@types/better-sqlite3": "^7.6.13",
    "inquirer": "^8.2.6",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-redux": "^9.1.0",
    "turbo": "latest",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@reduxjs/toolkit": "^2.11.2",
    "redux": "^5.0.1",
    "redux-observable": "^3.0.0-rc.3",
    "rxjs": "^7.8.2",
    "typescript": "^5.9.3",
    "ts-node": "^10.9.2",
    "@types/node": "^25.0.9",
    "node-localstorage": "^3.0.5",
    "better-sqlite3": "^12.6.2",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "monaco-editor": "^0.52.2"
  },
  "dependencies": {
    "react-native-svg": "^15.15.3"
  }
}
