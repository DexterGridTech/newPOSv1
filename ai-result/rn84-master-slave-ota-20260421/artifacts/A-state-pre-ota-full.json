    "kernel.base.workflow-runtime-v2.definitions": {
      "bySource": {
        "module": {
          "kernel.base.workflow-runtime-v2.builtin.single-read-barcode-from-camera": [
            {
              "workflowKey": "kernel.base.workflow-runtime-v2.builtin.single-read-barcode-from-camera",
              "moduleName": "kernel.base.workflow-runtime-v2",
              "name": "Single Read Barcode From Camera",
              "description": "Open camera scanner once and return the decoded barcode string.",
              "enabled": true,
              "version": "2026.04",
              "tags": [
                "builtin",
                "task",
                "barcode",
                "camera"
              ],
              "inputSchema": {
                "schemaType": "json-schema-lite",
                "properties": {
                  "scanMode": {
                    "type": "string"
                  },
                  "timeoutMs": {
                    "type": "number"
                  }
                }
              },
              "outputSchema": {
                "schemaType": "json-schema-lite",
                "required": [
                  "barcode"
                ],
                "properties": {
                  "barcode": {
                    "type": "string"
                  },
                  "format": {
                    "type": "string"
                  },
                  "raw": {
                    "type": "object"
                  }
                }
              },
              "rootStep": {
                "stepKey": "read-barcode",
                "name": "Read Barcode",
                "type": "external-call",
                "timeoutMs": 60000,
                "input": {
                  "object": {
                    "channel": {
                      "type": "INTENT",
                      "target": "camera",
                      "mode": "request-response"
                    },
                    "action": "com.impos2.posadapter.action.CAMERA_SCAN",
                    "timeoutMs": {
                      "type": "script",
                      "language": "javascript",
                      "source": "\n                            return typeof input.timeoutMs === 'number'\n                                ? input.timeoutMs\n                                : 60000\n                        "
                    },
                    "params": {
                      "type": "script",
                      "language": "javascript",
                      "source": "\n                            return {\n                                SCAN_MODE: input.scanMode || 'QR_CODE_MODE',\n                                waitResult: true\n                            }\n                        "
                    }
                  }
                },
                "output": {
                  "result": {
                    "type": "script",
                    "language": "javascript",
                    "source": "\n                        if (!params || params.success !== true) {\n                            throw new Error(params?.message || 'BARCODE_SCAN_FAILED')\n                        }\n                        const data = params.data || {}\n                        const barcode = data.SCAN_RESULT || data.scanResult || data.barcode\n                        if (typeof barcode !== 'string' || barcode.length === 0) {\n                            throw new Error('BARCODE_SCAN_EMPTY')\n                        }\n                        return {\n                            barcode,\n                            format: data.SCAN_RESULT_FORMAT || data.scanResultFormat || data.format || 'UNKNOWN',\n                            raw: params\n                        }\n                    "
                  }
                }
              },
              "timeoutMs": 60000,
              "defaultOptions": {
                "timeoutMs": 60000
              },
              "createdAt": 1776600000000,
              "updatedAt": 1776600000000
            }
          ]
        },
        "host": {},
        "remote": {},
        "test": {}
      },
