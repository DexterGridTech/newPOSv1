{
  "name": "@next/assembly-android-mixc-catering-assembly-rn84",
  "version": "1.0.0",
  "description": "Android RN84 assembly built on kernel-base and ui-base",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "start:clean": "react-native start --reset-cache",
    "android": "react-native run-android",
    "android:run": "react-native run-android --mode=debug",
    "test-visible:admin-loop": "node ../../../scripts/android-assembly-visible-admin-loop.mjs",
    "clean": "rm -rf node_modules && cd android && ./gradlew clean",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@next/host-runtime-rn84": "workspace:*",
    "@next/ui-integration-catering-shell": "workspace:*",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-svg": "^15.15.3",
    "react-redux": "^9.1.0",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "reactotron-core-client": "^2.9.9",
    "reactotron-react-native": "^5.1.18",
    "reactotron-redux": "^3.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "reactotron": {
    "emulatorHost": "localhost",
    "deviceHost": "192.168.0.172"
  },
  "assembly": {
    "adbSocketDebug": {
      "enabled": true
    }
  }
}
