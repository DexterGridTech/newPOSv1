{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["src/**/*", "electron/**/*", "*.ts"],
  "exclude": ["node_modules", "dist", ".webpack", "src/types/shims/**/*"]
}
