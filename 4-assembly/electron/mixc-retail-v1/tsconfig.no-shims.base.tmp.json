{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "paths": {
      "@impos2/adapter-electron-v1": [
        "../../../3-adapter/electron/adapterV1/src/renderer/index.ts"
      ],
      "@impos2/adapter-electron-v1/preload": [
        "../../../3-adapter/electron/adapterV1/src/preload/index.ts"
      ],
      "@impos2/adapter-electron-v1/renderer": [
        "../../../3-adapter/electron/adapterV1/src/renderer/index.ts"
      ],
      "@impos2/adapter-electron-v1/shared": [
        "../../../3-adapter/electron/adapterV1/src/shared/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "electron/**/*",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".webpack"
  ]
}