    "make": "yarn rebuild:native && electron-forge make",
    "lint": "eslint --ext .ts,.tsx .",
    "type-check": "tsc -p tsconfig.check.json"
  },
  "keywords": [],
  "author": "DexterYang",
  "license": "ISC",
  "dependencies": {
    "@impos2/adapter-electron-v1": "workspace:*",
