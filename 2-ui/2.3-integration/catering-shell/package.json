{
  "name": "@next/ui-integration-catering-shell",
  "version": "1.0.0",
  "description": "Catering integration shell built on ui-base packages",
  "author": "DexterYang",
  "license": "ISC",
  "exports": {
    ".": "./src/index.ts"
  },
  "react-native": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "build-for-product": "rm -rf dist && tsc -p tsconfig.json",
    "dev:web": "EXPO_OFFLINE=1 node ../../../node_modules/expo/bin/cli start --web --localhost",
    "web": "EXPO_OFFLINE=1 node ../../../node_modules/expo/bin/cli start --web --localhost",
    "expo:web": "EXPO_OFFLINE=1 node ../../../node_modules/expo/bin/cli start --web --localhost",
    "test-expo": "tsc -p test-expo/tsconfig.json --noEmit && node test-expo/runAutomation.mjs",
    "test-expo:visible": "tsc -p test-expo/tsconfig.json --noEmit && CATERING_SHELL_EXPO_HEADED=1 CATERING_SHELL_EXPO_SLOW_MS=700 CATERING_SHELL_EXPO_FINAL_PAUSE_MS=5000 node test-expo/runAutomation.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@next/kernel-base-runtime-shell-v2": "workspace:*",
    "@next/kernel-base-tcp-control-runtime-v2": "workspace:*",
    "@next/kernel-base-tdp-sync-runtime-v2": "workspace:*",
    "@next/kernel-base-topology-runtime-v3": "workspace:*",
    "@next/kernel-base-transport-runtime": "workspace:*",
    "@next/kernel-base-ui-runtime-v2": "workspace:*",
    "@next/kernel-business-catering-product-master-data": "workspace:*",
    "@next/kernel-business-catering-store-operating-master-data": "workspace:*",
    "@next/kernel-business-organization-iam-master-data": "workspace:*",
    "@next/ui-base-admin-console": "workspace:*",
    "@next/ui-base-input-runtime": "workspace:*",
    "@next/ui-base-runtime-react": "workspace:*",
    "@next/ui-base-terminal-console": "workspace:*",
    "@next/ui-base-test-support": "workspace:*",
    "@next/ui-business-catering-master-data-workbench": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.77",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.0",
    "expo": "~54.0.31",
    "expo-status-bar": "~3.0.9",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.0",
    "react-test-renderer": "19.2.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
