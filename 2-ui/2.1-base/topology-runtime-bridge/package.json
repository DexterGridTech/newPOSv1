    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@impos2/kernel-base-runtime-shell-v2": "workspace:*",
    "@impos2/kernel-base-topology-runtime-v3": "workspace:*",
