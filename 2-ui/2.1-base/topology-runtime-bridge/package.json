{
  "name": "@impos2/ui-base-topology-runtime-bridge",
  "version": "1.0.0",
  "description": "Topology-specific UI bridge for kernel topology runtime requests",
  "author": "DexterYang",
  "license": "ISC",
  "exports": {
    ".": "./src/index.ts",
    "./application": "./src/application/index.ts",
    "./types": "./src/types/index.ts"
  },
  "react-native": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "build-for-product": "rm -rf dist && tsc -p tsconfig.json",
