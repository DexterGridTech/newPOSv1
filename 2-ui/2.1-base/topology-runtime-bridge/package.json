  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.77",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.0",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.0",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
